# Terraform working dirs — provider binaries, module caches, plugin data.
# Regenerated by `terraform init`; never commit.
.terraform/
.terraformrc
terraform.rc

# Terraform state — may contain secrets and resource IDs. Use remote state.
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan artifacts and crash logs
*.tfplan
tfplan
crash.log
crash.*.log

# Local variable files — project IDs, CIDRs, org IDs, dotfiles repos.
# The *.example files are the committed templates.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Backend config — contains bucket / storage account / KMS key IDs that
# are operator-specific. Templates live as backend.hcl.example; the
# operator copies and fills them per-stack.
backend.hcl
!backend.hcl.example

# Override files (local-only customizations)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Claude Code per-user state (permissions, local settings)
.claude/

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS cruft
.DS_Store
Thumbs.db

# Credentials / auth material — belt and suspenders; these should never
# live in the repo to begin with.
*.json.key
*-sa-key.json
credentials.json
application_default_credentials.json
